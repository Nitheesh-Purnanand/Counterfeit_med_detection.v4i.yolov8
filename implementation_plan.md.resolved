# Implementation Plan: Dual-Stream Counterfeit Medicine Detection

## System Architecture

![Dual-Stream Architecture Diagram](C:\Users\HP\.gemini\antigravity\brain\3bb28303-e20f-4a4b-861c-f5a8a0a35f2a\architecture_diagram_1775852116934.png)

### Detailed Architecture Flowchart

```mermaid
flowchart TD
    %% ===== STAGE 1: DATA INPUT =====
    subgraph STAGE1["STAGE 1: Data Input"]
        A1["Raw Medicine Images<br/>Train: 4072 | Valid: 467 | Test: 65"]
        A2["YOLO Annotations<br/>.txt label files per image<br/>class_id x_center y_center w h"]
        A3["data.yaml<br/>Class 0: Authentic<br/>Class 1: Counterfeit"]
    end

    %% ===== STAGE 2: OBJECT DETECTION =====
    subgraph STAGE2["STAGE 2: Object Detection"]
        B1["YOLOv8n Model<br/>Pretrained on COCO"]
        B2["Fine-tune on Medicine Dataset<br/>50 epochs | 416x416 | batch=4"]
        B3["Trained Model<br/>runs/detect/train/weights/best.pt"]
        B4["Run Inference on ALL Images<br/>conf=0.25 | save_crop=True"]
        B5["Individual Medicine Crops<br/>runs/detect/predict/crops/"]
        B5A["authentic/<br/>~3500+ crops"]
        B5B["counterfeit/<br/>~1000+ crops"]
    end

    %% ===== STAGE 3: DATA PREPARATION =====
    subgraph STAGE3["STAGE 3: Data Preparation"]
        C1["Merge ALL Crops<br/>from train + valid + test"]
        C2["Assign Binary Labels<br/>authentic=0 | counterfeit=1"]
        C3["Stratified 80/20 Split<br/>random_state=42<br/>Preserves class ratio"]
        C3A["Training Set<br/>~80% of crops"]
        C3B["Test Set<br/>~20% of crops"]
    end

    %% ===== STAGE 4: DUAL STREAM EXTRACTION =====
    subgraph STAGE4["STAGE 4: Dual-Stream Feature Extraction"]
        direction LR
        
        subgraph STREAMA["STREAM A: Visual Features"]
            D1["Resize to 128x128<br/>BGR + Grayscale conversion"]
            D2["Color Histogram<br/>HSV colorspace<br/>8x8x8 bins = 512 dims"]
            D3["LBP Texture<br/>radius=3, points=24<br/>uniform method = 26 dims"]
            D4["GLCM Texture<br/>distances=[1,3], 3 angles<br/>5 properties = 5 dims"]
            D5["Hu Moments<br/>7 shape invariants<br/>log-transformed = 7 dims"]
            D6["HOG Gradients<br/>9 orient, 16x16 cells<br/>2x2 blocks = 1764 dims"]
            D7["Visual Feature Vector<br/>2314 dimensions"]
        end
        
        subgraph STREAMB["STREAM B: OCR Features"]
            E1["EasyOCR Engine<br/>Language: English"]
            E2["Text Detection<br/>Bounding boxes + text + confidence"]
            E3["Confidence Analysis<br/>avg, max, min, std"]
            E4["Text Quantity<br/>region count, char count"]
            E5["Spatial Analysis<br/>text area ratio, char density"]
            E6["OCR Feature Vector<br/>8 dimensions"]
        end
    end

    %% ===== STAGE 5: FUSION =====
    subgraph STAGE5["STAGE 5: Feature Fusion"]
        F1["Concatenate Streams<br/>Visual 2314 + OCR 8 = 2322 dims"]
        F2["StandardScaler<br/>zero mean, unit variance<br/>fit on train, transform test"]
        F3["3 Configurations Created"]
        F3A["Config A: Visual Only<br/>2314 features"]
        F3B["Config B: OCR Only<br/>8 features"]
        F3C["Config C: Fused<br/>2322 features"]
    end

    %% ===== STAGE 6: CLASSIFICATION =====
    subgraph STAGE6["STAGE 6: ML Classification (x3 configs)"]
        G1["Random Forest<br/>300 trees, Gini Index<br/>class_weight=balanced"]
        G2["Naive Bayes<br/>Gaussian assumption<br/>Bayes Theorem"]
        G3["KNN<br/>k=5, distance-weighted<br/>Euclidean metric"]
        G4["SVM<br/>RBF kernel, C=10<br/>class_weight=balanced"]
        G5["XGBoost<br/>300 trees, depth=6, lr=0.1<br/>scale_pos_weight"]
        G6["5-Fold Stratified<br/>Cross-Validation<br/>on each config"]
    end

    %% ===== STAGE 7: EVALUATION =====
    subgraph STAGE7["STAGE 7: Evaluation & Analysis"]
        H1["Per-Model Metrics<br/>Accuracy, Precision<br/>Recall, F1-Score"]
        H2["Confusion Matrices<br/>TP, TN, FP, FN<br/>per classifier"]
        H3["3-Config Comparison Table<br/>Visual vs OCR vs Fused<br/>15 rows: 5 models x 3 configs"]
        H4["Independent Test<br/>10 unseen images<br/>5 authentic + 5 counterfeit"]
    end

    %% ===== STAGE 8: EXPLAINABILITY =====
    subgraph STAGE8["STAGE 8: SHAP Explainability"]
        I1["TreeExplainer<br/>for RF & XGBoost"]
        I2["Global Summary Plot<br/>Top-20 features<br/>color-coded by group"]
        I3["Feature Group Importance<br/>Color vs LBP vs GLCM<br/>vs Hu vs HOG vs OCR"]
        I4["Stream Contribution<br/>Visual (A) vs OCR (B)<br/>relative importance"]
        I5["Per-Sample Explanations<br/>Force plots for<br/>correct & misclassified"]
        I6["Dependence Plots<br/>OCR confidence vs prediction<br/>interaction effects"]
    end

    %% ===== STAGE 9: OUTPUT =====
    subgraph STAGE9["STAGE 9: Final Output"]
        J1["Classification Result<br/>Authentic or Counterfeit"]
        J2["Contribution Summary<br/>Visual Only vs Fused<br/>improvement quantified"]
        J3["Publication-Ready<br/>Charts & Tables"]
    end

    %% ===== CONNECTIONS =====
    A1 --> B1
    A2 --> B1
    A3 --> B1
    B1 --> B2 --> B3 --> B4
